{
  "version": 2,
  "builds": [
    {
      "src": "api/main.go",
      "use": "@vercel/go"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/main.go",
      "headers": {
        "Cache-Control": "public, max-age=86400, s-maxage=43200, stale-while-revalidate=43200"
      }
    }
  ],
  "crons": [
    {
      "path": "/refresh",
      "schedule": "0 0 * * *"
    }
  ]
}
